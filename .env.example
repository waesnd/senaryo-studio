# ─────────────────────────────────────────────────────────────────────────────
# Scriptify — Environment Değişkenleri
# Bu dosyayı kopyalayıp .env.local olarak kaydet:
#   cp .env.example .env.local
# Sonra değerleri kendi hesap bilgilerinle doldur.
# ─────────────────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Sadece server-side API route'larında kullanılmalı (ASLA client'a sızdırma)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GROQ ──────────────────────────────────────────────────────────────────────
# console.groq.com > API Keys > Create API Key
# ⚠️ NEXT_PUBLIC_ ekleme — bu key sunucuda kalmalı
GROQ_API_KEY=gsk_...

# ── CLOUDINARY ────────────────────────────────────────────────────────────────
# cloudinary.com > Dashboard
# ⚠️ API_KEY ve API_SECRET NEXT_PUBLIC_ ekleme — sunucuda kalmalı
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
